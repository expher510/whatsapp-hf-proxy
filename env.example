# ── Hugging Face ──────────────────────────────
# Inference Endpoint URL بتاعك
HF_API_URL=https://api-inference.huggingface.co/models/YOUR_MODEL

# HF Token من: https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# ── Meta / WhatsApp Business API ──────────────
# Token من Meta Developer Dashboard
WA_TOKEN=EAAxxxxxxxxxxxxx

# Phone Number ID من Meta App Dashboard
WA_PHONE_ID=1234567890123456

# اختار كلمة سر عشوائية للـ Webhook Verification
VERIFY_TOKEN=my_secret_verify_token_123
